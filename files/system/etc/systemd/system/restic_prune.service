[Unit]
Description=Run Restic Prune
Wants=restic_prune.timer

[Service]
Type=oneshot
WorkingDirectory=/root
ExecStartPre=/bin/sleep 300
ExecStart=/usr/local/bin/runitor -uuid ${HC_PRUNE_UUID} -- /usr/local/bin/autorestic forget -a --prune
EnvironmentFile=-/etc/environment
EnvironmentFile=-/etc/restic.env

[Install]
WantedBy=multi-user.target
